{
  "id": "deepseek:legacy",
  "version": 1,
  "displayName": "DeepSeek Legacy",
  "displayNameI18n": {
    "ko": "DeepSeek Legacy"
  },
  "providerBaseId": "deepseek",
  "profileTier": "standard",
  "description": "Legacy DeepSeek Chat/Reasoner profile. These aliases are scheduled for discontinuation.",
  "descriptionI18n": {
    "ko": "Legacy DeepSeek Chat/Reasoner profile. These aliases are scheduled for discontinuation."
  },
  "visibility": "legacy",
  "lifecycle": "deprecated",
  "tags": [
    "deepseek",
    "legacy",
    "reasoning"
  ],
  "sortOrder": 9400,
  "modelId": "deepseek-chat",
  "endpoint": {
    "kind": "static",
    "url": "https://api.deepseek.com/chat/completions"
  },
  "auth": {
    "kind": "bearer",
    "fields": [
      "apiKey"
    ]
  },
  "defaults": {},
  "schema": [
    {
      "key": "modelId",
      "type": "string",
      "label": "Model ID",
      "description": "DeepSeek model identifier.",
      "required": true,
      "enum": [
        {
          "value": "deepseek-chat",
          "label": "DeepSeek Chat (legacy alias)"
        },
        {
          "value": "deepseek-reasoner",
          "label": "DeepSeek Reasoner (legacy alias)"
        }
      ],
      "mapsTo": {
        "target": "body",
        "path": "model"
      },
      "descriptionI18n": {
        "ko": "DeepSeek 모델 ID."
      }
    },
    {
      "key": "temperature",
      "type": "number",
      "label": "Temperature",
      "min": 0,
      "max": 2,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "temperature"
      }
    },
    {
      "key": "top_p",
      "type": "number",
      "label": "Top P",
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "top_p"
      }
    },
    {
      "key": "max_tokens",
      "type": "integer",
      "label": "Max Tokens",
      "min": 1,
      "max": 8192,
      "mapsTo": {
        "target": "body",
        "path": "max_tokens"
      }
    },
    {
      "key": "frequency_penalty",
      "type": "number",
      "label": "Frequency Penalty",
      "min": -2,
      "max": 2,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "frequency_penalty"
      }
    },
    {
      "key": "presence_penalty",
      "type": "number",
      "label": "Presence Penalty",
      "min": -2,
      "max": 2,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "presence_penalty"
      }
    },
    {
      "key": "stop",
      "type": "stringArray",
      "label": "Stop Sequences",
      "mapsTo": {
        "target": "body",
        "path": "stop"
      }
    },
    {
      "key": "response_format",
      "type": "string",
      "label": "Response Format",
      "enum": [
        {
          "value": "text",
          "label": "Text"
        },
        {
          "value": "json_object",
          "label": "JSON object"
        }
      ],
      "mapsTo": {
        "target": "body",
        "path": "response_format.type"
      }
    },
    {
      "key": "logprobs",
      "type": "boolean",
      "label": "Logprobs",
      "default": false,
      "mapsTo": {
        "target": "body",
        "path": "logprobs"
      }
    },
    {
      "key": "top_logprobs",
      "type": "integer",
      "label": "Top Logprobs",
      "min": 0,
      "max": 20,
      "mapsTo": {
        "target": "body",
        "path": "top_logprobs"
      }
    }
  ],
  "uiSchema": {
    "groups": [
      {
        "id": "credentials",
        "label": "Credentials",
        "order": 1,
        "labelI18n": {
          "ko": "인증 정보"
        }
      },
      {
        "id": "model",
        "label": "Model",
        "order": 2,
        "labelI18n": {
          "ko": "모델"
        }
      },
      {
        "id": "generation",
        "label": "Generation",
        "order": 3,
        "labelI18n": {
          "ko": "생성"
        }
      },
      {
        "id": "reasoning",
        "label": "Reasoning",
        "order": 4,
        "labelI18n": {
          "ko": "추론"
        }
      },
      {
        "id": "output",
        "label": "Output",
        "order": 4,
        "labelI18n": {
          "ko": "출력"
        }
      }
    ],
    "fields": [
      {
        "key": "apiKey",
        "widget": "secret",
        "visibility": "basic",
        "group": "credentials",
        "order": 1
      },
      {
        "key": "modelId",
        "widget": "combobox",
        "visibility": "basic",
        "group": "model",
        "order": 1
      },
      {
        "key": "temperature",
        "widget": "slider",
        "visibility": "basic",
        "group": "generation",
        "order": 1
      },
      {
        "key": "max_tokens",
        "widget": "number-input",
        "visibility": "basic",
        "group": "generation",
        "order": 2
      },
      {
        "key": "top_p",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 3
      },
      {
        "key": "frequency_penalty",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 4
      },
      {
        "key": "presence_penalty",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 5
      },
      {
        "key": "stop",
        "widget": "string-array",
        "visibility": "advanced",
        "group": "generation",
        "order": 6
      },
      {
        "key": "response_format",
        "widget": "select",
        "visibility": "advanced",
        "group": "output",
        "order": 1
      },
      {
        "key": "logprobs",
        "widget": "toggle",
        "visibility": "advanced",
        "group": "output",
        "order": 2
      },
      {
        "key": "top_logprobs",
        "widget": "number-input",
        "visibility": "advanced",
        "group": "output",
        "order": 3,
        "showIf": {
          "key": "logprobs",
          "equals": true
        }
      }
    ]
  },
  "capabilities": [
    "streaming",
    "reasoning"
  ],
  "sourceUrls": [
    "https://api-docs.deepseek.com/quick_start/pricing",
    "https://api-docs.deepseek.com/api/create-chat-completion",
    "https://api-docs.deepseek.com/updates/"
  ]
}
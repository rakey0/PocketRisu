{
  "id": "anthropic:opus-46",
  "version": 1,
  "displayName": "Claude Opus 4.6",
  "displayNameI18n": {
    "ko": "Claude Opus 4.6"
  },
  "providerBaseId": "anthropic",
  "profileTier": "standard",
  "description": "Claude Opus 4.6 profile. Adaptive thinking is preferred; manual thinking is legacy-compatible.",
  "descriptionI18n": {
    "ko": "Claude Opus 4.6 profile. Adaptive thinking is preferred; manual thinking is legacy-compatible."
  },
  "visibility": "standard",
  "lifecycle": "current",
  "tags": [
    "anthropic",
    "claude",
    "opus",
    "reasoning",
    "long-context"
  ],
  "sortOrder": 220,
  "modelId": "claude-opus-4-6",
  "endpoint": {
    "kind": "static",
    "url": "https://api.anthropic.com/v1/messages"
  },
  "auth": {
    "kind": "x-api-key",
    "fields": [
      "apiKey"
    ]
  },
  "defaults": {
    "max_tokens": 4096
  },
  "schema": [
    {
      "key": "modelId",
      "type": "string",
      "label": "Model ID",
      "description": "Claude model identifier.",
      "required": true,
      "enum": [
        {
          "value": "claude-opus-4-6",
          "label": "Claude Opus 4.6"
        }
      ],
      "mapsTo": {
        "target": "body",
        "path": "model"
      },
      "descriptionI18n": {
        "ko": "Claude 모델 ID."
      }
    },
    {
      "key": "max_tokens",
      "type": "integer",
      "label": "Max Tokens",
      "min": 1,
      "max": 128000,
      "mapsTo": {
        "target": "body",
        "path": "max_tokens"
      }
    },
    {
      "key": "temperature",
      "type": "number",
      "label": "Temperature",
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "temperature"
      }
    },
    {
      "key": "top_p",
      "type": "number",
      "label": "Top P",
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "top_p"
      }
    },
    {
      "key": "top_k",
      "type": "integer",
      "label": "Top K",
      "min": 0,
      "max": 500,
      "mapsTo": {
        "target": "body",
        "path": "top_k"
      }
    },
    {
      "key": "stop_sequences",
      "type": "stringArray",
      "label": "Stop Sequences",
      "mapsTo": {
        "target": "body",
        "path": "stop_sequences"
      }
    },
    {
      "key": "thinking_type",
      "type": "string",
      "label": "Thinking Mode",
      "enum": [
        {
          "value": "adaptive",
          "label": "Adaptive"
        },
        {
          "value": "enabled",
          "label": "Manual budget"
        }
      ],
      "default": "adaptive",
      "mapsTo": {
        "target": "body",
        "path": "thinking.type"
      }
    },
    {
      "key": "thinking_budget_tokens",
      "type": "integer",
      "label": "Thinking Budget Tokens",
      "min": 1024,
      "max": 32000,
      "mapsTo": {
        "target": "body",
        "path": "thinking.budget_tokens"
      }
    },
    {
      "key": "effort",
      "type": "string",
      "label": "Thinking Effort",
      "enum": [
        {
          "value": "low",
          "label": "Low"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "high",
          "label": "High"
        },
        {
          "value": "xhigh",
          "label": "Extra high"
        }
      ],
      "mapsTo": {
        "target": "body",
        "path": "output_config.effort"
      }
    },
    {
      "key": "service_tier",
      "type": "string",
      "label": "Service Tier",
      "enum": [
        {
          "value": "auto",
          "label": "Auto"
        },
        {
          "value": "standard_only",
          "label": "Standard only"
        }
      ],
      "mapsTo": {
        "target": "body",
        "path": "service_tier"
      }
    },
    {
      "key": "user_id",
      "type": "string",
      "label": "User ID (metadata)",
      "mapsTo": {
        "target": "body",
        "path": "metadata.user_id"
      }
    }
  ],
  "uiSchema": {
    "groups": [
      {
        "id": "credentials",
        "label": "Credentials",
        "order": 1,
        "labelI18n": {
          "ko": "인증 정보"
        }
      },
      {
        "id": "model",
        "label": "Model",
        "order": 2,
        "labelI18n": {
          "ko": "모델"
        }
      },
      {
        "id": "generation",
        "label": "Generation",
        "order": 3,
        "labelI18n": {
          "ko": "생성"
        }
      },
      {
        "id": "reasoning",
        "label": "Reasoning",
        "order": 4,
        "labelI18n": {
          "ko": "추론"
        }
      },
      {
        "id": "control",
        "label": "Control",
        "order": 5,
        "labelI18n": {
          "ko": "요청 제어"
        }
      }
    ],
    "fields": [
      {
        "key": "apiKey",
        "widget": "secret",
        "visibility": "basic",
        "group": "credentials",
        "order": 1
      },
      {
        "key": "modelId",
        "widget": "combobox",
        "visibility": "basic",
        "group": "model",
        "order": 1
      },
      {
        "key": "max_tokens",
        "widget": "number-input",
        "visibility": "basic",
        "group": "generation",
        "order": 1
      },
      {
        "key": "temperature",
        "widget": "slider",
        "visibility": "basic",
        "group": "generation",
        "order": 2
      },
      {
        "key": "top_p",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 3
      },
      {
        "key": "top_k",
        "widget": "number-input",
        "visibility": "advanced",
        "group": "generation",
        "order": 4
      },
      {
        "key": "stop_sequences",
        "widget": "string-array",
        "visibility": "advanced",
        "group": "generation",
        "order": 5
      },
      {
        "key": "thinking_type",
        "widget": "select",
        "visibility": "basic",
        "group": "reasoning",
        "order": 1
      },
      {
        "key": "effort",
        "widget": "select",
        "visibility": "basic",
        "group": "reasoning",
        "order": 2,
        "showIf": {
          "key": "thinking_type",
          "equals": "adaptive"
        }
      },
      {
        "key": "thinking_budget_tokens",
        "widget": "number-input",
        "visibility": "advanced",
        "group": "reasoning",
        "order": 3,
        "showIf": {
          "key": "thinking_type",
          "equals": "enabled"
        }
      },
      {
        "key": "service_tier",
        "widget": "select",
        "visibility": "advanced",
        "group": "control",
        "order": 1
      },
      {
        "key": "user_id",
        "widget": "text",
        "visibility": "advanced",
        "group": "control",
        "order": 2
      }
    ]
  },
  "headerTemplate": {
    "anthropic-version": "2023-06-01"
  },
  "capabilities": [
    "streaming",
    "reasoning",
    "vision",
    "tools",
    "json"
  ],
  "sourceUrls": [
    "https://platform.claude.com/docs/en/about-claude/models/overview",
    "https://platform.claude.com/docs/en/about-claude/models/model-ids-and-versions",
    "https://platform.claude.com/docs/en/build-with-claude/extended-thinking"
  ]
}
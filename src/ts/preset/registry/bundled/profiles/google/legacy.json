{
  "id": "google:legacy",
  "version": 1,
  "displayName": "Gemini Legacy",
  "displayNameI18n": {
    "ko": "Gemini Legacy"
  },
  "providerBaseId": "google",
  "profileTier": "standard",
  "description": "Legacy Gemini 2.0/1.5 compatibility profile.",
  "descriptionI18n": {
    "ko": "Legacy Gemini 2.0/1.5 compatibility profile."
  },
  "visibility": "legacy",
  "lifecycle": "legacy",
  "tags": [
    "google",
    "gemini",
    "legacy",
    "flash",
    "pro"
  ],
  "sortOrder": 9300,
  "modelId": "gemini-2.0-flash",
  "endpoint": {
    "kind": "static",
    "url": "https://generativelanguage.googleapis.com/v1beta/models"
  },
  "auth": {
    "kind": "x-goog-api-key",
    "fields": [
      "apiKey"
    ]
  },
  "defaults": {},
  "schema": [
    {
      "key": "modelId",
      "type": "string",
      "label": "Model ID",
      "description": "Gemini model identifier.",
      "required": true,
      "enum": [
        {
          "value": "gemini-2.0-flash",
          "label": "Gemini 2.0 Flash"
        },
        {
          "value": "gemini-1.5-pro",
          "label": "Gemini 1.5 Pro"
        },
        {
          "value": "gemini-1.5-flash",
          "label": "Gemini 1.5 Flash"
        },
        {
          "value": "gemini-1.5-flash-8b",
          "label": "Gemini 1.5 Flash 8B"
        }
      ],
      "mapsTo": {
        "target": "body",
        "path": "model"
      },
      "descriptionI18n": {
        "ko": "Gemini 모델 ID."
      }
    },
    {
      "key": "temperature",
      "type": "number",
      "label": "Temperature",
      "min": 0,
      "max": 2,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "generationConfig.temperature"
      }
    },
    {
      "key": "topP",
      "type": "number",
      "label": "Top P",
      "min": 0,
      "max": 1,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "generationConfig.topP"
      }
    },
    {
      "key": "topK",
      "type": "integer",
      "label": "Top K",
      "min": 1,
      "max": 1000,
      "mapsTo": {
        "target": "body",
        "path": "generationConfig.topK"
      }
    },
    {
      "key": "maxOutputTokens",
      "type": "integer",
      "label": "Max Output Tokens",
      "min": 1,
      "max": 65536,
      "mapsTo": {
        "target": "body",
        "path": "generationConfig.maxOutputTokens"
      }
    },
    {
      "key": "stopSequences",
      "type": "stringArray",
      "label": "Stop Sequences",
      "mapsTo": {
        "target": "body",
        "path": "generationConfig.stopSequences"
      }
    },
    {
      "key": "seed",
      "type": "integer",
      "label": "Seed",
      "mapsTo": {
        "target": "body",
        "path": "generationConfig.seed"
      }
    },
    {
      "key": "presencePenalty",
      "type": "number",
      "label": "Presence Penalty",
      "min": -2,
      "max": 2,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "generationConfig.presencePenalty"
      }
    },
    {
      "key": "frequencyPenalty",
      "type": "number",
      "label": "Frequency Penalty",
      "min": -2,
      "max": 2,
      "step": 0.01,
      "mapsTo": {
        "target": "body",
        "path": "generationConfig.frequencyPenalty"
      }
    },
    {
      "key": "thinkingBudget",
      "type": "integer",
      "label": "Thinking Budget",
      "min": 0,
      "max": 32768,
      "mapsTo": {
        "target": "body",
        "path": "generationConfig.thinkingConfig.thinkingBudget"
      }
    },
    {
      "key": "includeThoughts",
      "type": "boolean",
      "label": "Include Thoughts",
      "default": false,
      "mapsTo": {
        "target": "body",
        "path": "generationConfig.thinkingConfig.includeThoughts"
      }
    },
    {
      "key": "responseMimeType",
      "type": "string",
      "label": "Response Mime Type",
      "enum": [
        {
          "value": "text/plain",
          "label": "Text"
        },
        {
          "value": "application/json",
          "label": "JSON"
        }
      ],
      "mapsTo": {
        "target": "body",
        "path": "generationConfig.responseMimeType"
      }
    },
    {
      "key": "responseSchema",
      "type": "json",
      "label": "Response Schema",
      "mapsTo": {
        "target": "body",
        "path": "generationConfig.responseSchema"
      }
    },
    {
      "key": "responseLogprobs",
      "type": "boolean",
      "label": "Response Logprobs",
      "default": false,
      "mapsTo": {
        "target": "body",
        "path": "generationConfig.responseLogprobs"
      }
    },
    {
      "key": "logprobs",
      "type": "integer",
      "label": "Top Logprobs",
      "min": 1,
      "max": 20,
      "mapsTo": {
        "target": "body",
        "path": "generationConfig.logprobs"
      }
    },
    {
      "key": "safetySettings",
      "type": "json",
      "label": "Safety Settings",
      "mapsTo": {
        "target": "body",
        "path": "safetySettings"
      }
    }
  ],
  "uiSchema": {
    "groups": [
      {
        "id": "credentials",
        "label": "Credentials",
        "order": 1,
        "labelI18n": {
          "ko": "인증 정보"
        }
      },
      {
        "id": "model",
        "label": "Model",
        "order": 2,
        "labelI18n": {
          "ko": "모델"
        }
      },
      {
        "id": "generation",
        "label": "Generation",
        "order": 3,
        "labelI18n": {
          "ko": "생성"
        }
      },
      {
        "id": "reasoning",
        "label": "Reasoning",
        "order": 4,
        "labelI18n": {
          "ko": "추론"
        }
      },
      {
        "id": "output",
        "label": "Output",
        "order": 4,
        "labelI18n": {
          "ko": "출력"
        }
      }
    ],
    "fields": [
      {
        "key": "apiKey",
        "widget": "secret",
        "visibility": "basic",
        "group": "credentials",
        "order": 1
      },
      {
        "key": "modelId",
        "widget": "combobox",
        "visibility": "basic",
        "group": "model",
        "order": 1
      },
      {
        "key": "temperature",
        "widget": "slider",
        "visibility": "basic",
        "group": "generation",
        "order": 1
      },
      {
        "key": "maxOutputTokens",
        "widget": "number-input",
        "visibility": "basic",
        "group": "generation",
        "order": 2
      },
      {
        "key": "topP",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 3
      },
      {
        "key": "topK",
        "widget": "number-input",
        "visibility": "advanced",
        "group": "generation",
        "order": 4
      },
      {
        "key": "stopSequences",
        "widget": "string-array",
        "visibility": "advanced",
        "group": "generation",
        "order": 5
      },
      {
        "key": "seed",
        "widget": "number-input",
        "visibility": "advanced",
        "group": "generation",
        "order": 6
      },
      {
        "key": "presencePenalty",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 7
      },
      {
        "key": "frequencyPenalty",
        "widget": "slider",
        "visibility": "advanced",
        "group": "generation",
        "order": 8
      },
      {
        "key": "thinkingBudget",
        "widget": "number-input",
        "visibility": "basic",
        "group": "reasoning",
        "order": 1
      },
      {
        "key": "includeThoughts",
        "widget": "toggle",
        "visibility": "advanced",
        "group": "reasoning",
        "order": 2
      },
      {
        "key": "responseMimeType",
        "widget": "select",
        "visibility": "advanced",
        "group": "output",
        "order": 1
      },
      {
        "key": "responseSchema",
        "widget": "json",
        "visibility": "advanced",
        "group": "output",
        "order": 2
      },
      {
        "key": "responseLogprobs",
        "widget": "toggle",
        "visibility": "advanced",
        "group": "output",
        "order": 3
      },
      {
        "key": "logprobs",
        "widget": "number-input",
        "visibility": "advanced",
        "group": "output",
        "order": 4,
        "showIf": {
          "key": "responseLogprobs",
          "equals": true
        }
      },
      {
        "key": "safetySettings",
        "widget": "json",
        "visibility": "advanced",
        "group": "output",
        "order": 5
      }
    ]
  },
  "capabilities": [
    "streaming",
    "reasoning",
    "vision",
    "tools",
    "json"
  ],
  "sourceUrls": [
    "https://ai.google.dev/gemini-api/docs/models",
    "https://ai.google.dev/gemini-api/docs/thinking",
    "https://ai.google.dev/api/generate-content"
  ]
}